# Local runtime configuration (do not commit)
# Get values from SELISE Blocks Cloud Portal for your project/environment

# Server/Client microservice base URL
MICROSERVICE_API_BASE_URL=<YOUR_BLOCKS_API_URL>

# Public project key used in request header x-blocks-key
X_BLOCKS_KEY=<YOUR_BLOCKS_API_KEY>


# dotnet watch command for local development with hot reload

# dotnet watch --project src/Server -- --MICROSERVICE_API_BASE_URL=<YOUR_BLOCKS_API_URL> --X_BLOCKS_KEY=<YOUR_BLOCKS_API_KEY> --PROJECT_SLUG=your-project-slug
